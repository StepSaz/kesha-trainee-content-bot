# Claude
ANTHROPIC_API_KEY=sk-ant-...

# Tavily (web search for DM chat)
TAVILY_API_KEY=tvly-...

# Telegram
TELEGRAM_BOT_TOKEN=
# Webhook secret: sent to Telegram as secret_token by `npm run setup:boss-webhook`
# and verified by kesha-boss-background on every update. Generate with: openssl rand -hex 32
# REQUIRED in production (Netlify env vars) — without it forged updates are accepted.
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated Telegram user ids allowed to run /boss, /digest, /notes.
TELEGRAM_BOSS_USER_IDS=
TELEGRAM_CHAT_ID=@CtrlAltTherapy_test
TELEGRAM_TEST_CHAT_ID=@CtrlAltTherapy_test

# Mode & scheduling
KESHA_MODE=pipeline
KESHA_ENABLED=true

# Test endpoint auth (generate with: openssl rand -hex 32)
TEST_SECRET=

# Plan B (filled after running: npm run setup:managed)
MANAGED_AGENT_ID=
MANAGED_ENVIRONMENT_ID=
